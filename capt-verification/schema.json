{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CAPT Verification Report",
  "type": "object",
  "required": ["subject", "evidence", "release_confidence"],
  "properties": {
    "subject": {
      "type": "string",
      "description": "What is being verified (module, release, PR, deploy, benchmark)"
    },
    "evidence": {
      "type": "object",
      "properties": {
        "verified_this_session": { "type": "array", "items": { "type": "string" } },
        "previously_verified": { "type": "array", "items": { "type": "string" } },
        "inferred": { "type": "array", "items": { "type": "string" } },
        "needs_confirmation": { "type": "array", "items": { "type": "string" } },
        "known_limitations": { "type": "array", "items": { "type": "string" } },
        "human_validation": { "type": "array", "items": { "type": "string" } },
        "technical_validation": { "type": "array", "items": { "type": "string" } }
      }
    },
    "release_confidence": {
      "type": "string",
      "enum": ["DEPLOYED", "PARTIAL", "BLOCKED", "PENDING"],
      "description": "Concise readiness assessment derived from evidence"
    },
    "schema_version": { "type": "string", "default": "1.0.0" }
  }
}
